APIFY_API_TOKEN=
APIFY_TIMEOUT_SECONDS=300
APIFY_MAX_RETRIES=3
DISCOVERY_SOURCES_PATH=./config/discovery_sources.yaml

# Email Configuration
EMAIL_TO=your_email
EMAIL_FROM=your_email
EMAIL_PROVIDER=sendgrid

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here

# SMTP (alternative to SendGrid)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email
SMTP_PASSWORD=password

# Event Extraction
EVENT_LOOKAHEAD_DAYS=60
LLM_FALLBACK_ENABLED=false

# OpenAI — used only for targeted time/field extraction fallback
OPENAI_API_KEY=sk-...

# Comma-separated domains that always use Playwright (no shell detection)
PLAYWRIGHT_FORCE_DOMAINS=mbadrivein.com

# Storage
DATABASE_URL=sqlite:///./events.db

# Logging
LOG_LEVEL=INFO
